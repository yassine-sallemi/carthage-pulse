                      "spec": {
                        "dataset": "reddit",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "WITH minute_rates AS (\n    -- Step 1: Calculate the exact count for every single minute\n    SELECT \n        $__timeGroup(timestamp, '1m') AS time, \n        COUNT(*) AS elements_per_minute\n    FROM \n        raw_events\n    WHERE \n        $__timeFilter(timestamp) \n    GROUP BY \n        time\n)\n-- Step 2: Apply a rolling average to those minutes\nSELECT \n    time,\n    AVG(elements_per_minute) OVER (\n        ORDER BY time ASC \n        ROWS BETWEEN 4 PRECEDING AND CURRENT ROW\n    ) AS avg_5m_rate\nFROM \n    minute_rates\nORDER BY \n    time ASC;",
                        "sql": {
